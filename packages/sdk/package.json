{
  "name": "@rustag/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for RustAG - a mainnet-mirroring Solana staging environment",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShahiTechnovation/RustAG",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/ShahiTechnovation/RustAG#readme",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["solana", "litesvm", "testing", "rustag", "devtools"],
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
