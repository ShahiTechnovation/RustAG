{
  "name": "@rustag/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for RustAG — a mainnet-mirroring Solana staging environment",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["solana", "litesvm", "testing", "rustag", "devtools"],
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
