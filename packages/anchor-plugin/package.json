{
  "name": "@rustag/anchor-plugin",
  "version": "0.1.0",
  "description": "Anchor integration for RustAG — boot an ephemeral mainnet-mirroring stagenet for your Anchor tests",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["solana", "anchor", "litesvm", "testing", "rustag"],
  "dependencies": {
    "@rustag/sdk": "workspace:*"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": ">=0.30.0",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
