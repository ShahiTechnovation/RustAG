# RustAG environment configuration.
# Copy to `.env.local` and fill in your values.

# Mainnet RPC endpoint used by the lazy account mirror.
# A free Helius / Triton / QuickNode endpoint is strongly recommended over the
# public endpoint, which is aggressively rate-limited.
#   Helius:    https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
#   Public:    https://api.mainnet-beta.solana.com   (fallback, rate-limited)
RUSTAG_MAINNET_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Logging filter (tracing EnvFilter syntax).
RUST_LOG=rustag=debug,rustag_core=debug,rustag_rpc=info,tower_http=info

# Dashboard -> REST API base URL (consumed by the Next.js app).
NEXT_PUBLIC_RUSTAG_API_URL=http://localhost:9000

# --- Phase 2 -----------------------------------------------------------------

# Real-time mirror (requires building with `--features realtime`). Mainnet
# WebSocket endpoint for the `accountSubscribe` push stream.
#   RUSTAG_REALTIME_WS=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Cloud control plane (`rustag-cloud serve`).
RUSTAG_CLOUD_BIND=127.0.0.1:8080
RUSTAG_CLOUD_DB=rustag-cloud.sqlite
RUSTAG_CLOUD_DATA=.rustag-cloud
RUSTAG_CLOUD_DOMAIN=localhost
RUSTAG_CLOUD_PORT_START=20000
RUSTAG_CLOUD_PORT_END=21000
# Path to the rustag binary the control plane launches (default: `rustag` on PATH).
# RUSTAG_BIN=./target/release/rustag
