# RustAG environment configuration.
# Copy to `.env.local` and fill in your values.

# Mainnet RPC endpoint used by the lazy account mirror.
# A free Helius / Triton / QuickNode endpoint is strongly recommended over the
# public endpoint, which is aggressively rate-limited.
#   Helius:    https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
#   Public:    https://api.mainnet-beta.solana.com   (fallback, rate-limited)
RUSTAG_MAINNET_RPC=https://mainnet.helius-rpc.com/?api-key=41d316bc-ccb1-4c30-8086-806ada748a08

# Logging filter (tracing EnvFilter syntax).
RUST_LOG=rustag=debug,rustag_core=debug,rustag_rpc=info,tower_http=info

# Dashboard -> REST API base URL (consumed by the Next.js app).
NEXT_PUBLIC_RUSTAG_API_URL=http://localhost:9000
